---
import '../index.css';
import { affiliateLinks } from '../config/links';

interface Props {
	title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const isActivePath = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);

const navLinkClass = (href: string) =>
  [
    'relative rounded-md px-3 py-2 font-medium transition-colors',
    isActivePath(href)
      ? 'bg-blue-50 text-blue-700 after:absolute after:inset-x-3 after:-bottom-1 after:h-0.5 after:rounded-full after:bg-blue-600'
      : 'text-gray-600 hover:bg-gray-50 hover:text-blue-600'
  ].join(' ');
---

<!doctype html>
<html lang="zh-CN" style="scroll-behavior: smooth; scroll-padding-top: 130px;">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<slot name="head" />
	</head>
	<body>
		<div class="flex flex-col min-h-screen">
      {/* 顶部全局导航栏 */}
      <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
          <div class="flex items-center gap-8">
            <a href="/" class="text-xl font-bold text-blue-600">
              VPS推荐
            </a>
            <nav class="hidden md:flex items-center gap-2" aria-label="主导航">
              <a href="/" class={navLinkClass('/')} aria-current={isActivePath('/') ? 'page' : undefined}>首页</a>
              <a href="/cheap-vps/" class={navLinkClass('/cheap-vps/')} aria-current={isActivePath('/cheap-vps/') ? 'page' : undefined}>便宜 VPS</a>
              <a href="/foreign-trade-vps/" class={navLinkClass('/foreign-trade-vps/')} aria-current={isActivePath('/foreign-trade-vps/') ? 'page' : undefined}>外贸 VPS</a>
              <a href="/vps-for-proxy/" class={navLinkClass('/vps-for-proxy/')} aria-current={isActivePath('/vps-for-proxy/') ? 'page' : undefined}>搭梯子 VPS</a>
              <a href="/us-vps/" class={navLinkClass('/us-vps/')} aria-current={isActivePath('/us-vps/') ? 'page' : undefined}>美国 VPS</a>
            </nav>
          </div>
        </div>
      </header>

      {/* 页面内容区域 */}
      <main class="flex-1">
        <slot />
      </main>

      {/* 全局底部 */}
      <footer 
        class="relative overflow-hidden text-white py-14 mt-auto text-sm"
        style="background: radial-gradient(circle at 18% 15%, rgba(0, 163, 255, .55), transparent 28%), radial-gradient(circle at 85% 12%, rgba(0, 87, 255, .45), transparent 30%), linear-gradient(135deg, #06133d 0%, #07195d 46%, #03236f 100%)"
      >
        {/* 背景纹理，与 Hero 区域保持一致 */}
        <div 
          class="absolute inset-0 pointer-events-none opacity-45"
          style="background-image: linear-gradient(115deg, rgba(255,255,255,.08) 1px, transparent 1px), linear-gradient(25deg, rgba(0,163,255,.18) 1px, transparent 1px); background-size: 90px 90px, 140px 140px;"
        ></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-10">
            {/* 第一列：本站介绍 */}
            <div>
              <h3 class="text-lg font-bold mb-4 text-white">本站介绍</h3>
              <p class="text-blue-100/80 leading-relaxed">
                VPS推荐致力于为您提供最新、最真实的 VPS 选购指南。无论是新手建站、外贸独立站还是免备案内容站，我们都能帮您找到最适合的服务器方案。
              </p>
            </div>
            
            {/* 第二列：快速链接 */}
            <div>
              <h3 class="text-lg font-bold mb-4 text-white">快速链接</h3>
              <ul class="space-y-3">
                <li><a href="/" class="text-blue-100/80 hover:text-white transition-colors">关于我们</a></li>
                <li><a href="/" class="text-blue-100/80 hover:text-white transition-colors">联系我们</a></li>
              </ul>
            </div>
            
            {/* 第三列：地区导航 */}
            <div>
              <h3 class="text-lg font-bold mb-4 text-white">地区导航</h3>
              <ul class="space-y-3">
                <li><a href="/" class="text-blue-100/80 hover:text-white transition-colors">香港 VPS</a></li>
                <li><a href="/us-vps/" class="text-blue-100/80 hover:text-white transition-colors">美国 VPS</a></li>
                <li><a href="/" class="text-blue-100/80 hover:text-white transition-colors">韩国 VPS</a></li>
              </ul>
            </div>
            
            {/* 第四列：产品推荐 */}
            <div>
              <h3 class="text-lg font-bold mb-4 text-white">产品推荐</h3>
              <ul class="space-y-3">
                <li><a href={affiliateLinks.bandwagonhost} class="text-blue-100/80 hover:text-white transition-colors" target="_blank" rel="nofollow noopener noreferrer">搬瓦工 (Bandwagon)</a></li>
                <li><a href={affiliateLinks.lisahost} class="text-blue-100/80 hover:text-white transition-colors" target="_blank" rel="nofollow noopener noreferrer">丽莎主机</a></li>
              </ul>
            </div>
          </div>
          
          <div class="pt-8 border-t border-white/10 text-center text-blue-100/60">
            <p>© {new Date().getFullYear()} VPS推荐. All rights reserved.</p>
          </div>
        </div>
      </footer>
    </div>
	</body>
</html>
